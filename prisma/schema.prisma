generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
}

model Purchase {
  id          String   @id @default(cuid())
  itemName    String
  cost        Float
  date        String
  time        String
  category    String
  description String
  source      String
  createdAt   DateTime @default(now())
}
